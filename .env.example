# Supabase (Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only — never expose with a NEXT_PUBLIC_ prefix
SUPABASE_SECRET_KEY=sb_secret_...

# Stripe (paid tiers only — the free tier is provisioned at signup with no
# Stripe object or card)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# Used for Stripe redirect URLs and OAuth/MCP metadata in production
NEXT_PUBLIC_SITE_URL=https://betterfetch.co

# Transactional email (Resend). RESEND_API_KEY is required to send usage
# alerts; EMAIL_FROM is optional (defaults to no-reply@betterfetch.co).
RESEND_API_KEY=re_...
EMAIL_FROM=Better Fetch <no-reply@betterfetch.co>

# Shared secret the usage-alerts pg_cron sends as a bearer token. Must match
# the betterfetch_cron_secret stored in Supabase Vault.
CRON_SECRET=

# Optional — overrides the Better Fetch backend the MCP server proxies to.
# Defaults to https://api.betterfetch.co.
# BETTER_FETCH_API_URL=https://api.betterfetch.co
# Optional server-only static backend key. When set, the dashboard can ask the
# backend to close/delete warm browser profiles when users clear sessions.
# BETTER_FETCH_API_KEY=local-test-key

# Tool marketplace. TOOL_INGEST_SECRET authenticates tool-repo CI publishing
# to POST /api/ingest (same value as the better-fetch org secret
# BF_INGEST_SECRET). RUNNER_* point at the tool-runner Fly app (private
# network). PLAYGROUND_KMS_KEY encrypts per-user playground API keys at rest
# (32-byte hex, e.g. `openssl rand -hex 32`).
TOOL_INGEST_SECRET=
RUNNER_SHARED_SECRET=
# RUNNER_URL=http://better-fetch-runner.internal:8080
PLAYGROUND_KMS_KEY=

# Note: the Slack signup alert reads its bot token from Supabase Vault
# (slack_bot_token), not from app env — there is no SLACK_* var here.

# Blog content repo (posts/*.md with strict frontmatter — see that repo's
# README). The content repo's publish Action calls /api/revalidate with this
# secret as a bearer token so posts go live without a redeploy.
BLOG_REVALIDATE_SECRET=
# BLOG_REPO=PaulCrossland1/betterfetch-blog
# BLOG_BRANCH=main
# Only needed if the content repo is private (fine-grained PAT, read-only
# contents on that one repo).
# BLOG_GITHUB_TOKEN=github_pat_...
# Local preview: read posts from a directory instead of GitHub.
# BLOG_LOCAL_DIR=../blog/posts

# Inbound email → Slack (app/api/inbound). Resend Inbound POSTs received mail
# here; the route verifies the Svix signature and posts to Slack.
# RESEND_INBOUND_SECRET is the "whsec_..." signing secret from the Resend
# webhook config; SLACK_BOT_TOKEN is the bot token (xoxb-...) that also backs
# the signup/first-call alerts — the bot must be in the target channel.
RESEND_INBOUND_SECRET=whsec_...
SLACK_BOT_TOKEN=xoxb-...
# Slack channel that inbound emails are posted to (distinct from the
# signup/first-call alert channel). Defaults to C0BA5GULC7M in code.
SLACK_CHANNEL_INBOUND_CHANNEL=C0BA5GULC7M
